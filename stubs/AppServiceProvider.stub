        NativeBlade::name('{{APP_NAME}}');

        NativeBlade::desktop(function ($config) {
            $config->identifier('{{IDENTIFIER}}')
                ->size(1200, 800)
                ->minSize(800, 600)
                ->resizable();
        });

        NativeBlade::mobile(function ($config) {
            $config->orientation('portrait')
                ->statusBar(style: 'dark')
                ->splash(bg: '#0a0a0a');
        });

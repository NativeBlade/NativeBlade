@else
    <div class="min-h-screen flex flex-col">

        {{-- Header --}}
        <header class="fixed top-0 left-0 right-0 z-50 bg-[#0a0a0a] px-4 pb-3 flex items-center justify-between gap-4" style="padding-top:max(var(--nb-safe-top, 20px), 20px)">

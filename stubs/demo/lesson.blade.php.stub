                    $colors = ['#e74c3c','#f1c40f','#ffffff','#8B0000','#c0392b'];
                    $color = $colors[array_rand($colors)];
                    $left = rand(5, 95);
                    $delay = rand(0, 500) / 1000;
                    $dur = 2.5 + rand(0, 200) / 100;
                @endphp
                <div style="position:absolute;top:-20px;left:{{ $left }}%;width:12px;height:12px;background:{{ $color }};border-radius:2px;animation:nb-confetti {{ $dur }}s ease-in {{ $delay }}s both"></div>
            @endfor
        </div>


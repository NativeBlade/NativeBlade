<div>
<style>
    @keyframes nb-shake { 0%,100% { transform: translateX(0) } 20%,60% { transform: translateX(-8px) } 40%,80% { transform: translateX(8px) } }
    @keyframes nb-celebrate { 0% { transform: scale(1) } 50% { transform: scale(1.15) } 100% { transform: scale(1) } }
    @keyframes nb-fade-up { from { opacity: 0; transform: translateY(20px) } to { opacity: 1; transform: translateY(0) } }
    @keyframes nb-slide-up { from { transform: translateY(80px) } to { transform: translateY(0) } }
    @keyframes nb-slide-x { from { opacity: 0; transform: translateX(50px) } to { opacity: 1; transform: translateX(0) } }
    .nb-shake { animation: nb-shake 0.4s ease-in-out; }
    .nb-celebrate { animation: nb-celebrate 0.5s ease-in-out; }
    .nb-fade-up { animation: nb-fade-up 0.4s ease-out both; }
    .nb-slide-up { animation: nb-slide-up 0.3s ease-out both; }
    .nb-slide-x { animation: nb-slide-x 0.5s ease-out both; }
</style>

@if($finished)
    @php $perfect = $score === $totalQuestions; @endphp
    <style>
        @keyframes nb-confetti { 0% { transform:translateY(0) rotate(0deg);opacity:1 } 100% { transform:translateY(100vh) rotate(720deg);opacity:0 } }
        @keyframes nb-spring { 0% { transform:scale(0.5) rotate(-30deg) } 60% { transform:scale(1.1) rotate(5deg) } 100% { transform:scale(1) rotate(0deg) } }
        @keyframes nb-xp-fill { from { width: 80% } to { width: 100% } }
        @keyframes nb-shimmer { from { transform: translateX(-100%) skewX(-20deg) } to { transform: translateX(200%) skewX(-20deg) } }
        .nb-spring { animation: nb-spring 0.6s ease-out both; animation-delay: 0.1s; }
    </style>

    <div class="min-h-screen flex flex-col items-center justify-center p-6 relative overflow-hidden" style="padding-top:var(--nb-safe-top, 0px);padding-bottom:var(--nb-safe-bottom, 0px)">

        {{-- Confetti --}}
        <div class="absolute inset-0 pointer-events-none overflow-hidden">
            @for($i = 0; $i < 25; $i++)

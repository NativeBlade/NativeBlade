                <div class="h-4 bg-[#1a1a1a] rounded-full overflow-hidden border border-[#2a2a2a]">
                    <div class="h-full bg-[#f1c40f] rounded-full shadow-[0_0_15px_rgba(241,196,15,0.8)] relative overflow-hidden" style="width:{{ min(100, (($xp ?? 0) + $score * 10) % 200 / 2) }}%;animation:nb-xp-fill 1.2s ease-out 0.6s both">

                    <span class="text-[#f1c40f]">Level {{ intdiv($xp ?? 0, 200) + 1 }}</span>
                    <span class="text-[#9ca3af]">{{ $perfect ? 'Max Level!' : (($xp ?? 0) + $score * 10) . ' XP' }}</span>

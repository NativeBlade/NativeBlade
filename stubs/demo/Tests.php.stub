<?php

namespace App\Livewire;

use Livewire\Attributes\Layout;
use Livewire\Attributes\On;
use Livewire\Component;

#[Layout('components.layouts.app')]
class Tests extends Component
{
    public string $clipboardText = '';
    public array $osInfo = [];
    public array $location = [];
    public bool $biometricResult = false;
    public string $scanResult = '';
    public bool $confirmResult = false;

    #[On('nb:clipboard')]
    public function onClipboard($text)
    {
        $this->clipboardText = $text ?? '';
    }

    #[On('nb:os-info')]
    public function onOsInfo($info)
    {
        $this->osInfo = $info ?? [];
    }

    #[On('nb:geolocation')]
    public function onGeolocation($position)
    {
        $this->location = $position ?? [];
    }

    #[On('nb:biometric')]
    public function onBiometric($success)
    {
        $this->biometricResult = $success ?? false;
    }

    #[On('nb:scan')]
    public function onScan($result)
    {
        $this->scanResult = json_encode($result ?? []);
    }

    #[On('nb:confirm-result')]
    public function onConfirm($confirmed)
    {
        $this->confirmResult = $confirmed ?? false;
    }

    public function render()
    {
        return view('livewire.tests');
    }
}

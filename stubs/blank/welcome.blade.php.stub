        {{-- Counter --}}
        <div nb-animation="fadeInUp" nb-animation-delay="300ms" class="bg-[#111111] border border-[#2a2a2a] rounded-2xl px-8 py-6 mb-6 w-full">
            <p class="text-[10px] uppercase font-black text-[#6b7280] tracking-widest mb-2">Count</p>
            <p class="text-6xl font-black text-[#c0392b] tabular-nums">{{ $count }}</p>

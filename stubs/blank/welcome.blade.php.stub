<div class="min-h-screen bg-[#0a0a0a] flex flex-col items-center justify-center px-6">
    <div class="max-w-sm w-full flex flex-col items-center text-center">

        {{-- Logo --}}
        <div nb-animation="zoomIn" class="w-24 h-24 rounded-3xl bg-gradient-to-br from-[#8B0000] to-[#c0392b] flex items-center justify-center mb-8 shadow-[0_0_40px_rgba(192,57,43,0.4)]">
            <x-nativeblade-icon name="lightning-fill" size="48" class="text-white" />
        </div>

        {{-- Title --}}
        <h1 nb-animation="fadeInUp" nb-animation-delay="100ms" class="text-4xl font-black tracking-tight text-white mb-2">
            Welcome to NativeBlade
        </h1>
        <p nb-animation="fadeInUp" nb-animation-delay="200ms" class="text-[#9ca3af] text-sm mb-10 px-2">
            Edit <code class="text-[#c0392b] font-mono text-xs">resources/views/livewire/welcome.blade.php</code> and save to reload.

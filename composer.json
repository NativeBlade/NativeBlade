{
    "name": "nativeblade/nativeblade",
    "description": "Build desktop and mobile apps with Laravel + Livewire",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "NativeBlade\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "NativeBlade\\NativeBladeServiceProvider"
            ],
            "aliases": {
                "NativeBlade": "NativeBlade\\Facades\\NativeBlade"
            }
        }
    },
    "require": {
        "php": "8.3.*|8.4.*|8.5.*",
        "laravel/framework": "^11.0|^12.0|^13.0"
    }
}

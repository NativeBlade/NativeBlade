{
    "name": "nativeblade/nativeblade",
    "description": "Build desktop and mobile apps with Laravel + Livewire",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "NativeBlade\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "NativeBlade\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "NativeBlade\\NativeBladeServiceProvider"
            ],
            "aliases": {
                "NativeBlade": "NativeBlade\\Facades\\NativeBlade"
            }
        }
    },
    "require": {
        "php": "8.3.*|8.4.*|8.5.*",
        "laravel/framework": "^12.0|^13.0",
        "bacon/bacon-qr-code": "^3.0",
        "phpdocumentor/reflection-docblock": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0|^12.0",
        "orchestra/testbench": "^10.0|^11.0",
        "livewire/livewire": "^4.0"
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test:coverage": "vendor/bin/phpunit --coverage-text",
        "test:coverage-html": "vendor/bin/phpunit --coverage-html build/coverage"
    }
}

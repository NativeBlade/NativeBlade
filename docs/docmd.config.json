{
  "title": "NativeBlade",
  "url": "https://docs.nativeblade.dev",
  "src": "docs",
  "out": "site",
  "engine": "js",
  "favicon": "assets/images/favicon.png",
  "logo": {
    "light": "/assets/images/nb-logo.png",
    "dark": "/assets/images/nb-logo.png",
    "alt": "NativeBlade"
  },
  "layout": {
    "spa": true,
    "header": { "enabled": true },
    "sidebar": { "collapsible": true, "defaultCollapsed": false },
    "optionsMenu": {
      "position": "sidebar-top",
      "components": { "search": true, "themeSwitch": true }
    },
    "footer": {
      "style": "minimal",
      "content": "© 2026 NativeBlade — Laravel + Livewire, native.",
      "branding": false
    }
  },
  "theme": {
    "name": "default",
    "appearance": "system",
    "codeHighlight": true,
    "customCss": ["/assets/css/branding.css"]
  },
  "minify": true,
  "autoTitleFromH1": true,
  "copyCode": true,
  "pageNavigation": true,
  "versions": {
    "current": "sdk37",
    "position": "sidebar-top",
    "all": [
      { "id": "sdk37", "dir": "docs", "label": "SDK 37 (Latest)" }
    ]
  },
  "navigation": [
    { "title": "Introduction", "path": "/" },
    {
      "title": "Core",
      "collapsible": true,
      "children": [
        { "title": "Architecture", "path": "/core/architecture/" },
        { "title": "Action Response", "path": "/core/action-response/" },
        { "title": "Components", "path": "/core/components/" },
        { "title": "Native Shell Modules", "path": "/core/native-shell/" },
        { "title": "Animations", "path": "/core/animations/" },
        { "title": "Navigation", "path": "/core/navigation/" },
        { "title": "Lifecycle", "path": "/core/lifecycle/" },
        { "title": "Directives", "path": "/core/directives/" },
        { "title": "State Management", "path": "/core/state/" },
        { "title": "Platform Detection", "path": "/core/platform-detection/" },
        { "title": "Database", "path": "/core/database/" },
        { "title": "Filesystem", "path": "/core/filesystem/" },
        { "title": "Network", "path": "/core/network/" },
        { "title": "HTTP", "path": "/core/http/" },
        { "title": "Upload", "path": "/core/upload/" },
        { "title": "Cache", "path": "/core/cache/" },
        { "title": "Realtime", "path": "/core/realtime/" },
        { "title": "Scheduler", "path": "/core/scheduler/" },
        { "title": "Multi-language", "path": "/core/multi-language/" },
        { "title": "Plugins", "path": "/core/plugins/" }
      ]
